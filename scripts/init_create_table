===============================================
This scripts create all the tables and defining the columns' name and data type
===============================================

create table bronze.fran_list2026 (
	SAP_Store nvarchar(10),
	SN INT,
	Store_Number nvarchar(10),
	Area char(2),
	Franchise_Name nvarchar(50),
	RCB_Name nvarchar(50),
	RCB_No nvarchar(50),
	GST_No nvarchar(50),
	Store_Address text,
	Store_Tel nvarchar(50),
	Gender nvarchar(10),
	HP nvarchar(50),
	Official_Email nvarchar(200),
	Store_Franchise_Date date,
	OIC nvarchar(50),
	Name_in_NRIC nvarchar(50)
);

===1. check table exist > drop table if exist > create new table from scratch===
if object_ID ('bronze.SG7E_ACTIVE' , 'U') is not null
	drop table bronze.SG7E_ACTIVE;

create table bronze.SG7E_ACTIVE (
	Emp_ID NVARCHAR(20),
	SN INT,
	Company NVARCHAR(50),
	F_0R_C CHAR(1),
	NRIC_Name NVARCHAR(MAX),
	NRIC CHAR(9),
	ID_Card_Type NVARCHAR(50),
	Designation NVARCHAR(MAX),
	Location NVARCHAR(MAX),
	Store NVARCHAR(10),
	Area VARCHAR(10),
	District NVARCHAR(10),
	Date_Join NVARCHAR(50),
	Date_Resigned varchar (50),
	Service_Len DECIMAL(5,2),
	Group_Service_Len DECIMAL(5,2),
	Job_Category NVARCHAR(50),
	Divisional NVARCHAR(50),
	Contract_Term NVARCHAR(50),
	Type_of_Hours NVARCHAR(50),
	Contract_Start_Date varchar(20),
	Contract_End_Date varchar(20),
	Gender CHAR(1),
	Marital NVARCHAR(10),
	DOB varchar(50),
	Age DECIMAL (5,2),
	Race NVARCHAR(50),
	Nationality NVARCHAR(50),
	Highest_Education NVARCHAR(MAX),
	Column1 NVARCHAR(50),
	Column2 NVARCHAR(50),
	PERSONAL_Address NVARCHAR(MAX),
	Mobile NVARCHAR(20)
	);

===GUARDIAN AM LIST===
-- 1. check table exist > drop table if exist > create new table from scratch
if object_ID ('bronze.guardian_AMlist' , 'U') is not null
	drop table bronze.guardian_AMlist;

create table bronze.guardian_AMlist (
	Number int,
	AM varchar(10),
	Site_Code varchar(max),
	ABB varchar (10),
	Branch_Name varchar(max),
	AM_Email varchar(max)
	);

===SF EMP DATA LIST===
if OBJECT_ID ('bronze.SF_EMP_DATA' , 'u') is not null
drop table bronze.SF_EMP_DATA ;

create table bronze.SF_EMP_DATA(
	Team_Member_ID_Person_ID VARCHAR(50),
	User_Employee_ID VARCHAR(50),
	Legacy_Team_Member_ID VARCHAR(50),
	Payroll_ID VARCHAR(50),
	Employee_Status VARCHAR(50),
	Singapore_Full_Legal_Name VARCHAR(MAX),
	Position_Title VARCHAR(MAX),
	Banner VARCHAR(50),
	Banner_Name VARCHAR(50),
	Function_NAME VARCHAR(50),
	Job_Grade INT,
	Is_Fulltime_Employee VARCHAR(50),
	Nationality VARCHAR(50),
	Singapore_citizen VARCHAR(50),
	SG_Race VARCHAR(50),
	SG_Religion VARCHAR(50),
	Personal_Mobile_Phone VARCHAR(50),
	Business_Email_Address VARCHAR(50),
	Cost_Center_Code VARCHAR(50),
	Cost_Center_Name VARCHAR(50),
	Cost_Center_Budget_Group VARCHAR(50),
	Office_Store_Code VARCHAR(50),
	Office_StoreName VARCHAR(50),
	Business_Area VARCHAR(50),
